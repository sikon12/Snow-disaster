	local lp=game.Players.LocalPlayer local c=lp.Character if not c or not c:FindFirstChild("HumanoidRootPart") then return end local myPos,nearest,minDist=c.HumanoidRootPart.Position,nil,math.huge
	for _,v in ipairs(workspace:GetDescendants()) do local cfg=ItemConfig[v.Name] if cfg and SelectedItems[v.Name] then local p=(v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart"))) or (v:IsA("BasePart") and v) if p then local d=(p.Position-myPos).Magnitude if d<minDist then minDist=d nearest=p end end end end
