local function gradient(text,sc,ec)
	local r,t="",{} for u in text:gmatch("[%z\1-\127\194-\244][\128-\191]*") do table.insert(t,u) end
	local l=#t for i=1,l do local k=(i-1)/math.max(l-1,1) local rr,gg,bb=sc.R+(ec.R-sc.R)*k,sc.G+(ec.G-sc.G)*k,sc.B+(ec.B-sc.B)*k r=r..string.format('<font color="rgb(%d,%d,%d)">%s</font>',rr*255,gg*255,bb*255,t[i]) end return r
end

