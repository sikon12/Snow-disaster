-- 下拉框显示的选项（中文名）
local dropdownOptions = {}
for eng, chn in pairs(itemNameMap) do
    table.insert(dropdownOptions, chn)
end
table.sort(dropdownOptions, function(a, b) return a < b end)

-- 反向查找：中文名 → 英文名
local function chnToEng(chnName)
    for eng, chn in pairs(itemNameMap) do
        if chn == chnName then
            return eng
        end
    end
    return chnName
end

local espEnabled = false
local selectedItems = {}  -- 存储选中的英文名
local espHighlights = {}  -- 存储所有ESP效果

-- 创建单个物品的ESP
local function createESPForItem(item)
    if not item:IsA("Model") and not item:IsA("BasePart") then return end

    -- 检查是否已存在ESP
    if item:FindFirstChild("ESP_Highlight") then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = Color3.fromRGB(255, 50, 50)
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = item
    highlight.Parent = item

    -- 创建名称标签
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Label"
    billboard.Size = UDim2.new(0, 120, 0, 18)
    billboard.StudsOffset = Vector3.new(0, 2, 0)
    billboard.AlwaysOnTop = true
    billboard.Adornee = item
    billboard.Parent = item

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = itemNameMap[item.Name] or item.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
    textLabel.TextStrokeTransparency = 0
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.Font = Enum.Font.Gotham
    textLabel.TextSize = 12
    textLabel.Parent = billboard

    table.insert(espHighlights, {highlight = highlight, billboard = billboard, item = item})
end

-- 扫描并创建ESP
local function scanAndCreateESP()
    -- 清理旧的ESP
    for _, esp in pairs(espHighlights) do
        if esp.highlight then esp.highlight:Destroy() end
        if esp.billboard then esp.billboard:Destroy() end
    end
    espHighlights = {}

    if not espEnabled then return end

    local workspace = game:GetService("Workspace")
    for _, obj in pairs(workspace:GetDescendants()) do
        if itemNameMap[obj.Name] and selectedItems[obj.Name] then
            if obj:IsA("Model") or obj:IsA("BasePart") then
                createESPForItem(obj)
            end
        end
    end
end

-- 多选下拉框（Multi-Select Dropdown）
local Dropdown = Tabs.Tabgn:Dropdown({
    Title = "ESP 物品选择",
    Desc = "勾选需要ESP显示的物品（可多选）",
    Values = dropdownOptions,
    Multi = true,          -- 开启多选
    AllowNone = true,      -- 允许不选
    SearchBarEnabled = true,
    Callback = function(selected)
        -- selected 是 table，包含选中的中文名
        selectedItems = {}
        for _, chnName in pairs(selected) do
            local engName = chnToEng(chnName)
            selectedItems[engName] = true
        end
        -- 如果ESP已开启，重新扫描
        if espEnabled then
            scanAndCreateESP()
        end
    end
})

-- 开关 Toggle
local Toggle = Tabs.Tabgn:Toggle({
    Title = "ESP 开关",
    Desc = "开启/关闭物品ESP高亮",
    Value = false,
    Callback = function(state)
        espEnabled = state
        if state then
            scanAndCreateESP()
        else
            -- 关闭时清除所有ESP
            for _, esp in pairs(espHighlights) do
                if esp.highlight then esp.highlight:Destroy() end
                if esp.billboard then esp.billboard:Destroy() end
            end
            espHighlights = {}
        end
    end
})

-- ===================== 传送到物品功能 =====================

-- 传送按钮 Button（你传送到最近的已选物品）
local TeleportButton = Tabs.Tabgn:Button({
    Title = "传送到最近物品",
    Desc = "点击后你将传送到距离最近的一个已选物品旁边",
    Callback = function()
        local player = game:GetService("Players").LocalPlayer
        local character = player.Character
        if not character then return end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- 检查是否有选中物品
        if not next(selectedItems) then
            WindUI:Notify({
                Title = "提示",
                Content = "请先在列表中选择至少一个物品",
                Duration = 2,
            })
            return
        end

        local myPos = hrp.Position
        local closestItem = nil
        local closestDist = math.huge

        -- 遍历Workspace，找最近的已选物品
        for _, obj in pairs(game:GetService("Workspace"):GetDescendants()) do
            if itemNameMap[obj.Name] and selectedItems[obj.Name] then
                local part = nil
                if obj:IsA("Model") then
                    part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                elseif obj:IsA("BasePart") then
                    part = obj
                end
                if part then
                    local dist = (part.Position - myPos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closestItem = part
                    end
                end
            end
        end

        if closestItem then
            -- 传送到物品位置（上方3格，避免卡进去）
            hrp.CFrame = CFrame.new(closestItem.Position + Vector3.new(0, 3, 0))
            WindUI:Notify({
                Title = "传送成功",
                Content = "已传送到 " .. (itemNameMap[closestItem.Parent.Name] or closestItem.Parent.Name),
                Duration = 2,
            })
        else
            WindUI:Notify({
                Title = "提示",
                Content = "未找到已选中的物品",
                Duration = 2,
            })
        end
    end
})

-- ===================== 自动杀戮僵尸功能 =====================

local autoKillEnabled = false
local autoKillConnection = nil

local KillToggle = Tabs.Tabgn:Toggle({
    Title = "自动杀戮僵尸",
    Desc = "开启后自动攻击周围僵尸（间隔0.01秒）",
    Value = false,
    Callback = function(state)
        autoKillEnabled = state

        if state then
            autoKillConnection = game:GetService("RunService").Heartbeat:Connect(function()
                local player = game:GetService("Players").LocalPlayer
                local character = player.Character
                if not character then return end

                local bat = character:FindFirstChild("Bat")
                if not bat then return end

                local hitTargets = bat:FindFirstChild("HitTargets")
                if not hitTargets then return end

                local characters = workspace:WaitForChild("Characters")
                local zombie = characters:FindFirstChild("Zombie")
                if not zombie then return end

                local zombieHumanoid = zombie:FindFirstChild("Humanoid")
                if zombieHumanoid and zombieHumanoid.Health > 0 then
                    local args = {
                        {
                            zombie
                        }
                    }
                    hitTargets:FireServer(unpack(args))
                end

                task.wait(0.01)
            end)
        else
            if autoKillConnection then
                autoKillConnection:Disconnect()
                autoKillConnection = nil
            end
        end
    end
})
