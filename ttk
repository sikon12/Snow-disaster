local function createLayeredGlow(part, mainColor, glowColor)
	local isHead = part.Name == "Head"
	
	local baseColor = Color3.new(glowColor.R * 5, glowColor.G * 5, glowColor.B * 5)
	
	local glowAdornment
	if isHead then
		glowAdornment = Instance.new("CylinderHandleAdornment")
		glowAdornment.Height = part.Size.Y + 0.03
		glowAdornment.Radius = (part.Size.X * 0.5) + 0.03
		glowAdornment.CFrame = CFrame.new(Vector3.new(0, 0, 0), Vector3.new(0, 1, 0))
	else
		glowAdornment = Instance.new("BoxHandleAdornment")
		glowAdornment.Size = part.Size + Vector3.new(0.03, 0.03, 0.03)
	end
	
	glowAdornment.Name = "Chams"
	glowAdornment.AlwaysOnTop = true
	glowAdornment.ZIndex = isHead and 10 or 9
	glowAdornment.Adornee = part
	glowAdornment.Color3 = baseColor
	glowAdornment.Transparency = -1
	glowAdornment.Shading = Enum.AdornShading.XRayShaded
	glowAdornment.Parent = part
	
	local mainAdornment
	if isHead then
		mainAdornment = Instance.new("CylinderHandleAdornment")
		mainAdornment.Height = part.Size.Y + 0.02
		mainAdornment.Radius = (part.Size.X * 0.5) + 0.02
		mainAdornment.CFrame = CFrame.new(Vector3.new(0, 0, 0), Vector3.new(0, 1, 0))
	else
		mainAdornment = Instance.new("BoxHandleAdornment")
		mainAdornment.Size = part.Size + Vector3.new(0.02, 0.02, 0.02)
	end
	
	mainAdornment.Name = "Chams"
	mainAdornment.AlwaysOnTop = true
	mainAdornment.ZIndex = 10
	mainAdornment.Adornee = part
	mainAdornment.Color3 = mainColor
	mainAdornment.Transparency = 0
	mainAdornment.Parent = part
	
	return glowAdornment, mainAdornment
end

local function createHitModel(targetChar, hitPos, skinColor)
	if not targetChar then return end
	
	local clonedModel = targetChar:Clone()
	clonedModel.Name = "HitClone"
	clonedModel.Parent = hitModelFolder
	
	for _, part in ipairs(clonedModel:GetDescendants()) do
		if part:IsA("BasePart") then
			createLayeredGlow(part, skinColor, skinColor)
		end
		
		if part:IsA("Script") or part:IsA("LocalScript") or part:IsA("ModuleScript") then
			part:Destroy()
		end
		
		if part:IsA("Humanoid") then
			part:Destroy()
		end
	end
	
	if clonedModel.PrimaryPart then
		clonedModel:SetPrimaryPartCFrame(CFrame.new(hitPos))
	elseif clonedModel:FindFirstChild("HumanoidRootPart") then
		clonedModel.HumanoidRootPart.CFrame = CFrame.new(hitPos)
	end
	
	task.delay(5, function()
		clonedModel:Destroy()
	end)
end

local function createBulletBeam(origin, hitPos, targetChar)
	local skin = getRandomBeamSkin()
	
	local att0 = Instance.new("Attachment")
	att0.Position = Vector3.new(0, 0, 0)
	att0.Parent = workspace.Terrain
	att0.WorldPosition = origin
	
	local att1 = Instance.new("Attachment")
	att1.Position = Vector3.new(0, 0, 0)
	att1.Parent = workspace.Terrain
	att1.WorldPosition = hitPos
	
	local beam = Instance.new("Beam")
	beam.FaceCamera = true
	beam.Width0 = 0.2
	beam.Width1 = 0.2
	beam.Color = skin.Beam.Color
	beam.LightEmission = skin.Beam.LightEmission or 1
	beam.LightInfluence = 0
	beam.Transparency = NumberSequence.new(0.1)
	beam.Attachment0 = att0
	beam.Attachment1 = att1
	beam.Parent = beamFolder
	
	if skin.Particle then
		local particle = skin.Particle:Clone()
		particle.Parent = att1
	end
	
	if skin.ShotParticle then
		local shotParticle = skin.ShotParticle:Clone()
		shotParticle.Parent = att1
		if skin.ParticleEmit then
			shotParticle:Emit(skin.ParticleEmit)
		end
	end
	
	if skin.ShotParticle2 then
		local shotParticle2 = skin.ShotParticle2:Clone()
		shotParticle2.Parent = att1
		if skin.ParticleEmit then
			shotParticle2:Emit(skin.ParticleEmit)
		end
	end
	
	local beamColor = skin.Beam.Color.Keypoints[1].Value
	createHitModel(targetChar, hitPos, beamColor)
	
	task.delay(5, function()
		beam:Destroy()
		att0:Destroy()
		att1:Destroy()
	end)
end

