local function getCurrentWeapon()
	local attrWeapon = player:GetAttribute("CurrentWeapon")
	if attrWeapon and typeof(attrWeapon) == "string" then
		return attrWeapon
	end
	
	local char = player.Character
	if char then
		for _, child in ipairs(char:GetChildren()) do
			if child:IsA("Tool") then
				return child.Name
			end
		end
		for _, child in ipairs(char:GetChildren()) do
			if child:IsA("Model") then
				local hasBarrel = child:FindFirstChild("Barrel")
				local hasMagazine = child:FindFirstChild("Magazine")
				local hasHandle = child:FindFirstChild("Handle")
				
				if (hasBarrel and hasMagazine) or (hasBarrel and hasHandle) then
					return child.Name
				end
			end
		end
	end
	
	local cam = workspace.CurrentCamera
	if cam then
		for _, child in ipairs(cam:GetChildren()) do
			if child:IsA("Model") then
				local hasBarrel = child:FindFirstChild("Barrel")
				local hasMagazine = child:FindFirstChild("Magazine")
				local hasHandle = child:FindFirstChild("Handle")
				
				if (hasBarrel and hasMagazine) or (hasBarrel and hasHandle) then
					return child.Name
				end
			end
		end
	end
	
	return nil
end

local function isDead(part)
	local check = part
	while check and check ~= workspace do
		if check:GetAttribute("Dead") == true then
			return true
		end
		check = check.Parent
	end
	return false
end

local function hasWallBetween(fromPos, toPos)
	local direction = (toPos - fromPos)
	local distance = direction.Magnitude
	
	if distance < 0.1 then return false end
	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	
	local filterList = {}
	table.insert(filterList, player.Character)
	table.insert(filterList, workspace.CurrentCamera)
	
	local mercPlayers = workspace:FindFirstChild("MercPlayers")
	if mercPlayers then
		table.insert(filterList, mercPlayers)
	end
	
	local activeMap = workspace:FindFirstChild("ActiveMap") or workspace:FindFirstChild("Map")
	if activeMap then
		local touchables = activeMap:FindFirstChild("Touchables")
		if touchables then
			table.insert(filterList, touchables)
		end
		local ignore = activeMap:FindFirstChild("Ignore")
		if ignore then
			table.insert(filterList, ignore)
		end
	end
	
	local ignoreFolder = workspace:FindFirstChild("Ignore")
	if ignoreFolder then
		table.insert(filterList, ignoreFolder)
	end
	
	raycastParams.FilterDescendantsInstances = filterList
	
	local rayResult = workspace:Raycast(fromPos, direction.Unit * (distance - 0.1), raycastParams)
	
	return rayResult ~= nil
end

local function getClosestTarget()
	local char = player.Character
	if not char then return nil, nil, nil, nil, nil end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return nil, nil, nil, nil, nil end

	local myUserId = player.UserId
	local closestDist = math.huge
	local closestUserId = nil
	local closestHitPos = nil
	local closestBodyPart = nil
	local closestChar = nil

	local tagged = CollectionService:GetTagged("MercBodyPart")
	for _, part in ipairs(tagged) do
		if part:IsA("BasePart") and part.Parent then
			if isDead(part) then
				continue
			end

			local ownerId = part:GetAttribute("OwnerUserId")
			local bodyPartName = part:GetAttribute("MercBodyPart")
			local targetChar = part:FindFirstAncestorOfClass("Model")

			if not ownerId or not bodyPartName then
				if targetChar then
					ownerId = ownerId or targetChar:GetAttribute("OwnerUserId")
					bodyPartName = bodyPartName or part.Name
				end
			end

			if ownerId and typeof(ownerId) == "number" and ownerId ~= myUserId and bodyPartName then
				local dist = (root.Position - part.Position).Magnitude
				if dist < closestDist then
					if not hasWallBetween(root.Position, part.Position) then
						closestDist = dist
						closestUserId = ownerId
						closestHitPos = part.Position
						closestBodyPart = bodyPartName
						closestChar = targetChar
					end
				end
			end
		end
	end

	if closestUserId and closestHitPos and closestBodyPart then
		local direction = (closestHitPos - root.Position).Unit
		return closestUserId, closestHitPos, direction, closestBodyPart, closestChar
	end
	return nil, nil, nil, nil, nil
end

-- ============================================================
-- 启动 / 停止 Ragebot
-- ============================================================
local shotSequence = 0

local function startRagebot()
	if ragebotEnabled then return end
	ragebotEnabled = true
	screenGui.Enabled = true

	-- Hit / Kill 事件监听
	hitConn = BulletController.HitConfirmed:Connect(function()
		hitCount = hitCount + 1
		statsLabel.Text = string.format("K:%d | H:%d", killCount, hitCount)
	end)

	killConn = BulletController.KillConfirmed:Connect(function()
		killCount = killCount + 1
		statsLabel.Text = string.format("K:%d | H:%d", killCount, hitCount)
	end)

	-- 主循环
	heartbeatConn = RunService.Heartbeat:Connect(function()
		local weapon = getCurrentWeapon()
		if not weapon then return end

		if weapon ~= currentWeaponName then
			currentWeaponName = weapon
			currentFireRate = getWeaponFireRate(weapon)
			local rpm = math.floor(60 / currentFireRate)
			weaponLabel.Text = string.format("%s | %d RPM", weapon, rpm)
			statsLabel.Text = string.format("K:%d | H:%d", killCount, hitCount)
			sendNotification("武器识别", string.format("%s | %d RPM", weapon, rpm))
			print(string.format("[自动识别] 武器: %s | 射速: %.3f秒 | %d RPM", weapon, currentFireRate, rpm))
		end

		local currentTime = tick()
		if currentTime - lastAttackTime < currentFireRate then
			return
		end

		local targetUserId, hitPos, direction, bodyPart, targetChar = getClosestTarget()
		if not (targetUserId and hitPos and direction and bodyPart) then return end

		local char = player.Character
		if not char then return end
		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then return end

		local randomBodyPart = getRandomBodyPart()
		if randomBodyPart then
			bodyPart = randomBodyPart
		end

		local origin = root.Position
		shotSequence = shotSequence + 1
		attackCount = attackCount + 1
		lastAttackTime = currentTime
		
		currentTarget = tostring(targetUserId)
		currentBodyPart = bodyPart
		
		WeaponFired:FireServer(weapon, origin, direction, targetUserId, shotSequence)
		MercHitClaim:FireServer(weapon, targetUserId, bodyPart, origin, direction, hitPos, shotSequence)
		
		createBulletBeam(origin, hitPos, targetChar)
		
		targetLabel.Text = string.format("目标: #%s | 部位: %s", currentTarget, currentBodyPart)
		
		if attackCount % 100 == 0 then
			print(string.format("[统计] 攻击:%d | 击杀:%d | 命中:%d | 武器:%s", attackCount, killCount, hitCount, weapon))
		end
	end)

	sendNotification("Ragebot", "已开启")
	print("[Ragebot] 已开启")
end

local function stopRagebot()
	if not ragebotEnabled then return end
	ragebotEnabled = false
	screenGui.Enabled = false

	-- 断开所有连接，强制停止逻辑
	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end
	if hitConn then
		hitConn:Disconnect()
		hitConn = nil
	end
	if killConn then
		killConn:Disconnect()
		killConn = nil
	end

	-- 重置状态
	currentWeaponName = nil
	currentTarget = "无"
	currentBodyPart = "无"
	weaponLabel.Text = ""
	statsLabel.Text = ""
	targetLabel.Text = ""

	sendNotification("Ragebot", "已关闭")
	print("[Ragebot] 已关闭 — 所有逻辑已停止")
end

-- ============================================================
-- UI 开关
-- ============================================================
Tabs.Tabgn:Toggle({
	Title = "愤怒机器人",
	Default = false,
	Callback = function(state)
		if state then
			startRagebot()
		else
			stopRagebot()
		end
	end,
})
