-- ★ 唯一开关：自动进行
local autoRunning = false
local autoThread = nil

Tabs.Tabgn:Toggle({
    Title = "自动进行",
    Default = false,
    Callback = function(state)
        autoRunning = state

        if autoRunning then
            autoThread = task.spawn(function()
                while autoRunning do
                    pcall(function()
                        ReplicatedStorage:WaitForChild("Msg")
                            :WaitForChild("Click")
                            :FireServer()
                    end)
                    task.wait(0.01)
                end
            end)
        else
            if autoThread then
                task.cancel(autoThread)
                autoThread = nil
            end
        end
    end
})
