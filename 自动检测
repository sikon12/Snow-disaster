local function unlock()
    if humanoid and rootPart then
        humanoid.PlatformStand = false
        rootPart.Anchored = false
        humanoid.AutoRotate = true
    end
end

local function translate(targetPos, actionName)
    if not isFlying then return end
    local startPos = rootPart.Position
    local dist = (targetPos - startPos).Magnitude
    if dist < 1 then return end
    local steps = math.max(10, math.floor(dist / 2))
    local stepTime = dist / (MOVE_SPEED * steps)
    for i = 1, steps do
        if not isFlying then return end
        rootPart.CFrame = CFrame.new(startPos:Lerp(targetPos, i / steps))
        RunService.Heartbeat:Wait()
        task.wait(stepTime)
    end
    rootPart.CFrame = CFrame.new(targetPos)
    print("✅ " .. actionName)
end

local function flyUpToAbove(wp, idx)
    local pos = Vector3.new(wp.X, wp.Y + FLY_UP_HEIGHT, wp.Z)
    translate(pos, "上浮到航点" .. idx .. "上方")
end

local function flyToNextWaypoint(nextWp, curIdx)
    translate(nextWp, "飞到航点" .. (curIdx + 1))
end

-- ========== 自动飞行主循环 ==========
function startAutoFly()
    while isFlying do
        for i = currentWaypointIndex, #waypoints do
            if not isFlying then break end
            currentWaypointIndex = i
            local curWp = waypoints[i]
            local nextWp = waypoints[i + 1]
            local hasNext = nextWp ~= nil

            lockForFlight()
            flyUpToAbove(curWp, i)
            if hasNext then
                flyToNextWaypoint(nextWp, i)
            else
                print("🏁 到达最后一个航点")
            end

            task.wait(1)
            unlock()
            print("🕒 允许自由移动 2 秒")
            task.wait(2)
        end
        currentWaypointIndex = 1
        print("🔄 本轮结束，重新开始")
        task.wait(1)
    end
end

