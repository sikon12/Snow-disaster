-- ===== Hitbox 功能 =====
local hitboxLoops = {}
local originalSizes = {}
local originalCanCollide = {}
local originalTransparency = {}

local function processPlayerHitbox(plr, enable)
    local char = plr.Character
    if not char then return end
    
    local hitboxParts = {}
  
    local hitboxHead = char:FindFirstChild("Hitbox_Head")
    if hitboxHead and hitboxHead:IsA("BasePart") then
        table.insert(hitboxParts, hitboxHead)
    end
 
    local head = char:FindFirstChild("Head")
    if head then
        local headHitbox = head:FindFirstChild("Hitbox_Head")
        if headHitbox and headHitbox:IsA("BasePart") then
            table.insert(hitboxParts, headHitbox)
        end
        if head:IsA("BasePart") then
            table.insert(hitboxParts, head)
        end
    end
    
    local humanoidRootPart = char:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart and humanoidRootPart:IsA("BasePart") then
        table.insert(hitboxParts, humanoidRootPart)
    end
  
    if #hitboxParts == 0 then
        local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
        if torso and torso:IsA("BasePart") then
            table.insert(hitboxParts, torso)
        end
    end
    
    if #hitboxParts == 0 then return end
    
    for _, hitbox in ipairs(hitboxParts) do
        if enable then
            if not originalSizes[plr] then
                originalSizes[plr] = {}
            end
            if not originalSizes[plr][hitbox] then
                originalSizes[plr][hitbox] = hitbox.Size
                originalCanCollide[plr] = originalCanCollide[plr] or {}
                originalCanCollide[plr][hitbox] = hitbox.CanCollide
                originalTransparency[plr] = originalTransparency[plr] or {}
                originalTransparency[plr][hitbox] = hitbox.Transparency
            end
           
            hitbox.Size = Vector3.new(10, 10, 10)
            hitbox.CanCollide = false
            hitbox.Transparency = 0.5
        else
            if originalSizes[plr] and originalSizes[plr][hitbox] then
                hitbox.Size = originalSizes[plr][hitbox]
                originalSizes[plr][hitbox] = nil
            end
            if originalCanCollide[plr] and originalCanCollide[plr][hitbox] ~= nil then
                hitbox.CanCollide = originalCanCollide[plr][hitbox]
                originalCanCollide[plr][hitbox] = nil
            end
            if originalTransparency[plr] and originalTransparency[plr][hitbox] ~= nil then
                hitbox.Transparency = originalTransparency[plr][hitbox]
                originalTransparency[plr][hitbox] = nil
            end
        end
    end
end

Tabs.Tabgn:Toggle({
    Title = "Hitbox",
    Icon = "target",
    Value = false,
    Callback = function(state)
        if state then
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and not hitboxLoops[plr] then
                    local loop = task.spawn(function()
                        while true do
                            processPlayerHitbox(plr, true)
                            task.wait(0.1)
                        end
                    end)
                    hitboxLoops[plr] = loop
                end
            end
            
            Players.PlayerAdded:Connect(function(plr)
                if plr == LocalPlayer then return end
                if not hitboxLoops[plr] then
                    plr.CharacterAdded:Wait()
                    task.wait(1)
                    local loop = task.spawn(function()
                        while true do
                            processPlayerHitbox(plr, true)
                            task.wait(0.1)
                        end
                    end)
                    hitboxLoops[plr] = loop
                end
            end)
            
            Players:GetPlayers()
            
            print("已开启Hitbox")
        else
            for plr, loop in pairs(hitboxLoops) do
                if loop then
                    task.cancel(loop)
                end
                processPlayerHitbox(plr, false)
            end
            
            hitboxLoops = {}
            originalSizes = {}
            originalCanCollide = {}
            originalTransparency = {}
            
            print("已关闭Hitbox修改")
        end
    end
})

