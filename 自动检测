-- 墙壁检测函数
local function checkWall(localCameraPos, targetHeadPos)
    if not wallCheck then 
        return true 
    end
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local localCharacter = LocalPlayer.Character
    local filterList = {Workspace.CurrentCamera}
    
    if localCharacter then
        for _, part in ipairs(localCharacter:GetDescendants()) do
            if part:IsA("BasePart") then
                table.insert(filterList, part)
            end
        end
    end
    
    raycastParams.FilterDescendantsInstances = filterList
    raycastParams.IgnoreWater = true
    
    local direction = (targetHeadPos - localCameraPos).Unit
    local distance = (localCameraPos - targetHeadPos).Magnitude
    
    local raycastResult = Workspace:Raycast(localCameraPos, direction * distance, raycastParams)
    
    if raycastResult then
        local hitPart = raycastResult.Instance
        
        if hitPart then
            local hitCharacter = hitPart:FindFirstAncestorWhichIsA("Model")
            local targetCharacter = targetHeadPos:FindFirstAncestorWhichIsA("Model")
            
            if hitCharacter and targetCharacter and hitCharacter == targetCharacter then
                return true
            end
            
            local currentPart = hitPart
            while currentPart do
                if currentPart == targetHeadPos then
                    return true
                end
                currentPart = currentPart.Parent
            end
            
            return false
        end
    end
    
    return true
end

-- 获取所有有效目标
local function getValidTargets()
    local targets = {}
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local head = character:FindFirstChild("Head")
            
            if humanoid and humanoid.Health > 0 and head then
                table.insert(targets, {
                    Type = "Player",
                    Model = character,
                    Head = head,
                    Humanoid = humanoid
                })
            end
        end
    end
    
    if aimNPCs then
        for _, npc in ipairs(workspace:GetDescendants()) do
            if npc:IsA("Model") and npc:FindFirstChild("Humanoid") then
                local humanoid = npc:FindFirstChild("Humanoid")
                local head = npc:FindFirstChild("Head")
                
                local isPlayer = false
                for _, player in ipairs(Players:GetPlayers()) do
                    if player.Character == npc then
                        isPlayer = true
                        break
                    end
                end
                
                if not isPlayer and humanoid and humanoid.Health > 0 and head then
                    table.insert(targets, {
                        Type = "NPC",
                        Model = npc,
                        Head = head,
                        Humanoid = humanoid
                    })
                end
            end
        end
    end
    
    return targets
end

