local function ListRemotes()
    local remotes = {}
    local function Scan(folder, path)
        for _, v in ipairs(folder:GetChildren()) do
            local fullPath = path .. "." .. v.Name
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                table.insert(remotes, fullPath)
            end
            if #v:GetChildren() > 0 and not v:IsA("LocalScript") and not v:IsA("Script") then
                Scan(v, fullPath)
            end
        end
    end
    pcall(function() Scan(ReplicatedStorage, "ReplicatedStorage") end)
    return remotes
end

local function GetWeaponExit(character)
    if not character then return nil end
    local tool = character:FindFirstChildWhichIsA("Tool")
    if not tool then return nil end

    local exit = tool:FindFirstChild("Exit") or tool:FindFirstChild("Muzzle") or tool:FindFirstChild("FirePoint")
    if exit then return exit, tool.Name end

    for _, part in ipairs(tool:GetDescendants()) do
        if part:IsA("BasePart") and (part.Name:lower():find("muzzle") or part.Name:lower():find("exit") or part.Name:lower():find("fire")) then
            return part, tool.Name
        end
    end

    local hrp = character:FindFirstChild("HumanoidRootPart")
    return hrp, tool.Name
end

local function GetTarget()
    local bossFolder = AwaitingBosses:FindFirstChild("Boss")
    if bossFolder then
        local bossModel = bossFolder:FindFirstChildWhichIsA("Model") or bossFolder:FindFirstChildWhichIsA("BasePart")
        if bossModel then
            local hitbox = bossModel:FindFirstChild("Head") or bossModel:FindFirstChild("HumanoidRootPart") or (bossModel:IsA("BasePart") and bossModel)
            if hitbox then return hitbox end
        end
    end
    for _, zombie in ipairs(ActiveZombies:GetChildren()) do
        local hitbox = zombie:FindFirstChild("Head") or zombie:FindFirstChild("HumanoidRootPart")
        if hitbox then return hitbox end
    end
    return nil
end

task.spawn(function()
    while true do
        if AutoKillEnabled then
            pcall(function()
                local Character = LocalPlayer.Character
                if not Character then return end

                local exitPart, weaponName = GetWeaponExit(Character)
                if not exitPart or not weaponName then return end

                local targetPart = GetTarget()
                if not targetPart then return end

                local originPos = exitPart.Position
                local targetPos = targetPart.Position
                local direction = (targetPos - originPos).Unit

                local success = pcall(function()
                    Event:FireServer(
                        weaponName,
                        {{targetPart, targetPos, direction}},
                        {{weaponName, originPos, targetPos, targetPos, true, targetPart, false, false, "Default", exitPart}}
                    )
                end)

                if not success then
                    pcall(function()
                        Event:FireServer(weaponName, targetPart, targetPos)
                    end)
                end
            end)
        end
        task.wait(0.05)
    end
end)

-- ===================== ESP 功能 =====================
local ESPEnabled = false
local ESP_COLOR = Color3.fromRGB(255, 0, 0)
local LINE_COLOR = Color3.fromRGB(255, 0, 0)
local LINE_THICKNESS = 0.06
local MAX_DISTANCE = 500

local espData = {}

local function CreateOrUpdateESP(zombie)
    if not zombie or not zombie:IsA("Model") then return end

    local head = zombie:FindFirstChild("Head") or zombie:FindFirstChild("HumanoidRootPart")
    if not head then return end

    local data = espData[zombie]
    if not data then
        local hl = Instance.new("Highlight")
        hl.Name = "ZombieESP"
        hl.FillColor = ESP_COLOR
        hl.OutlineColor = Color3.fromRGB(255, 80, 80)
        hl.FillTransparency = 0.5
        hl.OutlineTransparency = 0.2
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = zombie
        hl.Parent = CoreGui

        local line = Instance.new("Part")
        line.Name = "ZombieLine"
        line.Material = Enum.Material.Neon
        line.Color = LINE_COLOR
        line.Transparency = 0.3
        line.Anchored = true
        line.CanCollide = false
        line.CanQuery = false
        line.Size = Vector3.new(LINE_THICKNESS, LINE_THICKNESS, 2)
        line.Parent = Workspace.CurrentCamera

        espData[zombie] = { highlight = hl, linePart = line }
        data = espData[zombie]
    end

    local cam = Workspace.CurrentCamera
    if cam then
        local topCenter = cam.ViewportSize.X / 2
        local topPos = cam:ScreenPointToRay(topCenter, 0, 1).Origin + cam.CFrame.UpVector * 2
        local headPos = head.Position
        local distance = (headPos - topPos).Magnitude

        if distance > MAX_DISTANCE then
            data.linePart.Transparency = 1
            data.highlight.Enabled = false
        else
            data.linePart.Transparency = 0.3
            data.highlight.Enabled = true
            data.linePart.Size = Vector3.new(LINE_THICKNESS, LINE_THICKNESS, distance)
            data.linePart.CFrame = CFrame.new(topPos, headPos) * CFrame.new(0, 0, -distance / 2)
        end
    end
end

local function RemoveESP(zombie)
    local data = espData[zombie]
    if data then
        if data.highlight then data.highlight:Destroy() end
        if data.linePart then data.linePart:Destroy() end
        espData[zombie] = nil
    end
end

local function ClearAllESP()
    for zombie, _ in pairs(espData) do
        RemoveESP(zombie)
    end
end

local function ESPUpdate()
    while true do
        if ESPEnabled then
            for _, zombie in ipairs(ActiveZombies:GetChildren()) do
                if zombie:IsA("Model") then
                    CreateOrUpdateESP(zombie)
                end
            end
            for zombie, _ in pairs(espData) do
                if not zombie or not zombie.Parent then
                    RemoveESP(zombie)
                end
            end
        else
            for _, data in pairs(espData) do
                if data.highlight then data.highlight.Enabled = false end
                if data.linePart then data.linePart.Transparency = 1 end
            end
        end
        task.wait(0.05)
    end
end

ActiveZombies.ChildAdded:Connect(function(child)
    if ESPEnabled and child:IsA("Model") then
        task.wait(0.1)
        CreateOrUpdateESP(child)
    end
end)

ActiveZombies.ChildRemoved:Connect(function(child)
    RemoveESP(child)
end)

task.spawn(ESPUpdate)

-- ===================== 删除受伤方块（TouchLava）=====================
local RemoveLavaEnabled = false
local touchLavaPath = Workspace:WaitForChild("TouchLava", 5)

local function RemoveTouchLava()
    pcall(function()
        if touchLavaPath and touchLavaPath.Parent then
            touchLavaPath:Destroy()
            print("[删除受伤方块] TouchLava 已删除")
        end
    end)
end

local function RestoreTouchLava()
    pcall(function()
        -- 检查是否已存在
        local existing = Workspace:FindFirstChild("TouchLava")
        if not existing then
            local newFolder = Instance.new("Folder")
            newFolder.Name = "TouchLava"
            newFolder.Parent = Workspace
            touchLavaPath = newFolder
            print("[删除受伤方块] TouchLava 已恢复")
        else
            touchLavaPath = existing
        end
    end)
end

-- 持续监控：如果开启状态下 TouchLava 被重新创建，再次删除
task.spawn(function()
    while true do
        if RemoveLavaEnabled then
            pcall(function()
                local existing = Workspace:FindFirstChild("TouchLava")
                if existing then
                    existing:Destroy()
                end
            end)
        end
        task.wait(0.5)
    end
end)

