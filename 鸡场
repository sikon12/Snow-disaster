CharacterTab:Toggle({
    Title = "漂浮",
    Value = false,
    Callback = function(value)
        FloatEnabled = value
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if FloatEnabled and hrp then
            if FloatForce then FloatForce:Destroy() end
            FloatForce = Instance.new("BodyVelocity")
            FloatForce.Name = "FloatVelocity"
            FloatForce.MaxForce = Vector3.new(0, 100000, 0)
            FloatForce.Velocity = Vector3.new(0, 0, 0)
            FloatForce.Parent = hrp
        else
            if FloatForce then
                FloatForce:Destroy()
                FloatForce = nil
            end
        end
    end,
})

CharacterTab:Toggle({
    Title = "击飞所有",
    Value = false,
    Callback = function(value)
        FlingAllEnabled = value
        if value then
            if FlingAllThread then return end
            FlingAllThread = task.spawn(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hrp and hum then
                    hum.PlatformStand = true
                    local spinForce = Instance.new("BodyAngularVelocity")
                    spinForce.Name = "TrollSpin"
                    spinForce.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    spinForce.AngularVelocity = Vector3.new(0, 50000, 0)
                    spinForce.Parent = hrp
                    while FlingAllEnabled do
                        for _, targetPlayer in pairs(Players:GetPlayers()) do
                            if targetPlayer ~= LocalPlayer and FlingAllEnabled then
                                local targetChar = targetPlayer.Character
                                local targetHrp = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
                                if targetHrp then
                                    local timer = tick()
                                    while FlingAllEnabled and tick() - timer < 0.2 and targetHrp.Parent do
                                        hrp.CFrame = targetHrp.CFrame
                                        hrp.Velocity = Vector3.new(math.random(-5000, 5000), 5000, math.random(-5000, 5000))
                                        task.wait(0.01)
                                    end
                                end
                            end
                        end
                        task.wait()
                    end
                    if hrp:FindFirstChild("TrollSpin") then hrp.TrollSpin:Destroy() end
                    hrp.Velocity = Vector3.new(0, 0, 0)
                    hum.PlatformStand = false
                end
                FlingAllThread = nil
            end)
        else
            if FlingAllThread then
                repeat task.wait() until FlingAllThread == nil
            end
        end
    end,
})

